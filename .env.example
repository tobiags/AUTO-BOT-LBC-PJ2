# ── DATABASE ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autotransfert:password@localhost:5432/autotransfert_p2

# ── REDIS / CELERY ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── HETZNER ───────────────────────────────────────────────────────────
# (info server — utilisé dans scripts de déploiement)
VPS_IP=

# ── SMSTOOLS ─────────────────────────────────────────────────────────
SMSTOOLS_API_KEY=
SMSTOOLS_WEBHOOK_SECRET=

# ── IPROXY.ONLINE ─────────────────────────────────────────────────────
IPROXY_API_KEY=
IPROXY_PROXY_ID=

# ── SMSAPP.IO (OTP jetables) ─────────────────────────────────────────
SMSAPP_API_TOKEN=

# ── MAILGUN ───────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_WEBHOOK_SIGNING_KEY=
OPERATIONAL_DOMAIN=

# ── SENTRY ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── BROWSER-USE CLOUD (Mode B fallback) ───────────────────────────────
BROWSER_USE_API_KEY=

# ── PATCHRIGHT ────────────────────────────────────────────────────────
# Répertoire des profils de session (persistance cookies DataDome)
SESSIONS_DIR=/opt/lbc_sessions

# ── APP ───────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-in-production
# Fenêtre horaire SMS (heure de Paris)
SMS_HOUR_START=8
SMS_HOUR_END=20
# Pool comptes LBC — minimum à maintenir
LBC_ACCOUNTS_MIN_ACTIVE=3
